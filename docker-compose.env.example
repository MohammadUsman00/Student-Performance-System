# Copy to `.env` next to docker-compose.yml (Docker Compose loads it automatically):
#   copy docker-compose.env.example .env
#
# --- Required: frontend build (Convex Cloud deployment URL) ---
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# --- Optional host port overrides ---
# FRONTEND_HOST_PORT=8080
# ML_HOST_PORT=8000

# Convex runs outside Docker. For ML actions to reach this stack's ml-service from the
# internet, set on your Convex deployment:
#   npx convex env set ML_SERVICE_URL https://your-public-url-to-port-8000
